{
  "version": 2,
  "builds": [
    {
      "src": "api/send-otp.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "logo.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/send-otp",
      "dest": "/api/send-otp.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}